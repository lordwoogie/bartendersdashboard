# Google Calendar - iCal Feeds (no API key needed!)
# Get from: Google Calendar → click 3 dots on calendar → Settings → Integrate calendar → Secret address in iCal format
# Comma-separated URLs for multiple calendars (taproom events, food trucks, etc.)
GOOGLE_ICAL_URLS=https://calendar.google.com/calendar/ical/YOUR_TAPROOM_CAL/private-XXX/basic.ics,https://calendar.google.com/calendar/ical/YOUR_FOODTRUCK_CAL/private-YYY/basic.ics

# Untappd for Business API
# Get from: business.untappd.com → API settings
UNTAPPD_API_URL=https://business.untappd.com/api/v1
UNTAPPD_API_KEY=your-untappd-api-key

# PredictHQ - Local events, holidays
# Get from: predicthq.com → API Access
PREDICTHQ_API_KEY=your-predicthq-api-key

# Eventbrite - Local events
# Get from: eventbrite.com/platform/api
EVENTBRITE_API_KEY=your-eventbrite-api-key

# OpenWeatherMap - Daily weather
# Get from: openweathermap.org/api (free tier)
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# Email - Resend
# Get from: resend.com → API Keys
RESEND_API_KEY=your-resend-api-key

# Email recipients (comma-separated)
EMAIL_RECIPIENTS=manager@example.com,bartender@example.com

# Admin password
ADMIN_PASSWORD=change-this-password

# balldontlie.io NBA API (optional - has free tier)
# Get from: balldontlie.io
BALLDONTLIE_API_KEY=your-balldontlie-api-key

# Cron secret - protects /api/cron from unauthorized access
# Set to any random string; Vercel Cron sends this automatically
CRON_SECRET=your-random-cron-secret

# Deputy - Staff scheduling
# Get from: Deputy → Developer → OAuth Clients → Get An Access Token
DEPUTY_BASE_URL=https://your-install.na.deputy.com
DEPUTY_ACCESS_TOKEN=your-deputy-access-token
